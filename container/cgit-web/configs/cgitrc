root-title=GitBox
root-desc=Minimal self-hosted Git server

remove-suffix=1

enable-index-owner=0
enable-log-filecount=1
enable-log-linecount=1
enable-blame=1
enable-commit-graph=1

virtual-root=/repos/
clone-url=gitbox:repos/$CGIT_REPO_URL.git ssh://git@gitbox:2222/~/repos/$CGIT_REPO_URL.git

readme=:README.md
readme=:readme.md
readme=:README
readme=:README.txt

about-filter=/usr/lib/cgit/filters/about-formatting.sh
source-filter=/usr/lib/cgit/filters/syntax-highlighting.py

section-from-path=1
scan-path=/srv/git
